DRAPIXAI_GPU_PRESET=runpod-a100
DRAPIXAI_DEVICE=cuda
DRAPIXAI_CUDA_DEVICE=0
DRAPIXAI_REDIS_URL=redis://127.0.0.1:6379/0
DRAPIXAI_QUEUE_NAME=drapixai_tryon
DRAPIXAI_MODEL_DIR=/workspace/drapixai/models/idm_vton
DRAPIXAI_GARMENT_CACHE_DIR=/workspace/drapixai/runtime/garments
DRAPIXAI_OUTPUT_FORMAT=png
DRAPIXAI_ENABLE_XFORMERS=1
DRAPIXAI_ENABLE_TF32=1
DRAPIXAI_ENABLE_VAE_TILING=1
DRAPIXAI_ENABLE_CPU_OFFLOAD=0
DRAPIXAI_ADMIN_TOKEN=replace-with-a-long-random-secret
DRAPIXAI_GARMENT_CACHE_BACKEND=local
DRAPIXAI_S3_ENDPOINT=
DRAPIXAI_S3_BUCKET=drapixai-prod
DRAPIXAI_S3_REGION=us-east-1
DRAPIXAI_S3_ACCESS_KEY_ID=
DRAPIXAI_S3_SECRET_ACCESS_KEY=

