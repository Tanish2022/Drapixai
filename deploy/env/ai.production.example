DRAPIXAI_GPU_PRESET=runpod-a100
DRAPIXAI_DEVICE=cuda
DRAPIXAI_CUDA_DEVICE=0
DRAPIXAI_REDIS_URL=redis://127.0.0.1:6379/0
DRAPIXAI_QUEUE_NAME=drapixai_tryon
DRAPIXAI_TRYON_ENGINE=catvton
DRAPIXAI_MODEL_DIR=/workspace/drapixai/models/catvton
DRAPIXAI_CATVTON_MODEL_DIR=/workspace/drapixai/models/catvton
DRAPIXAI_CATVTON_REPO_ID=zhengchong/CatVTON
DRAPIXAI_CATVTON_MASK_SOURCE=automasker
DRAPIXAI_CATVTON_SKIP_SAFETY_CHECK=1
DRAPIXAI_CANDIDATE_COUNT=4
DRAPIXAI_MIN_QUALITY_SCORE=0.72
DRAPIXAI_ENABLE_REFINEMENT=0
DRAPIXAI_ENABLE_UPSCALE=0
DRAPIXAI_GARMENT_CACHE_DIR=/workspace/drapixai/runtime/garments
DRAPIXAI_OUTPUT_FORMAT=png
DRAPIXAI_INPUT_MAX_SIDE=640
DRAPIXAI_ENHANCED_STEPS=36
DRAPIXAI_ENHANCED_GUIDANCE=3.0
DRAPIXAI_JOB_TIMEOUT=1800
DRAPIXAI_MAX_WAIT=300
DRAPIXAI_LOW_VRAM=0
DRAPIXAI_OPENPOSE_DEVICE=cuda
DRAPIXAI_PRELOAD_MODEL=1
DRAPIXAI_ENABLE_XFORMERS=1
DRAPIXAI_ENABLE_TF32=1
DRAPIXAI_ENABLE_VAE_TILING=1
DRAPIXAI_ENABLE_CPU_OFFLOAD=0
DRAPIXAI_ADMIN_TOKEN=replace-with-a-long-random-secret
DRAPIXAI_GARMENT_CACHE_BACKEND=local
DRAPIXAI_S3_ENDPOINT=
DRAPIXAI_S3_BUCKET=drapixai-prod
DRAPIXAI_S3_REGION=us-east-1
DRAPIXAI_S3_ACCESS_KEY_ID=
DRAPIXAI_S3_SECRET_ACCESS_KEY=
