NODE_ENV=production
PORT=8000
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/drapixai
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-a-long-random-secret
DRAPIXAI_AI_URL=http://RUNPOD_POD_IP:8080
DRAPIXAI_CORS_ORIGINS=https://drapixai.com,https://www.drapixai.com
DRAPIXAI_TRUST_PROXY=1
DRAPIXAI_MAX_UPLOAD_BYTES=10485760
DRAPIXAI_REQUIRE_GARMENT_CACHE=1
DRAPIXAI_GARMENT_APPROVAL_REQUIRED=0
DRAPIXAI_ADMIN_TOKEN=replace-with-a-long-random-secret
DRAPIXAI_ADMIN_EMAIL=admin@drapixai.com
DRAPIXAI_ADMIN_PASSWORD=replace-with-a-strong-admin-password
DRAPIXAI_ADMIN_USER_ID=0
DRAPIXAI_ENTERPRISE_QUOTA=100000
BILLING_UPGRADE_URL=https://drapixai.com/pricing
S3_BUCKET=drapixai-prod
AWS_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@drapixai.com
