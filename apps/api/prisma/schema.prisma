generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           Int      @id @default(autoincrement())
  email                        String   @unique
  emailVerifiedAt              DateTime?
  passwordHash                 String
  companyName                  String?
  mobileNumber                 String?
  themePreference              String   @default("dark")
  storeVerificationToken       String?
  storeVerifiedAt              DateTime?
  catalogSyncSource            String?
  catalogFeedUrl               String?
  catalogLastSyncedAt          DateTime?
  catalogLastSyncStatus        String?
  planType                     String   @default("trial")
  selectedPlan                 String?
  subscriptionPlan             String?
  subscriptionStatus           String?
  subscriptionProvider         String?
  subscriptionCustomerId       String?
  subscriptionId               String?
  subscriptionCurrentPeriodEndsAt DateTime?
  trialExpiresAt               DateTime?
  createdAt                    DateTime @default(now())
  apiKeys                      ApiKey[]
  catalogProducts              CatalogProduct[]
  emailLogs                    EmailLog[]
  garments                     Garment[]
  garmentMatches               GarmentMatch[]
  tryOnResults                 TryOnResult[]
  tryOnFeedback                TryOnFeedback[]
  verificationCodes            VerificationCode[]
}

model ApiKey {
  id              Int      @id @default(autoincrement())
  userId          Int
  keyHash         String   @unique
  domainWhitelist String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
  renders         Render[]
  usages          Usage[]
  dailyUsages     UsageDaily[]
  tryOnResults    TryOnResult[]
}

model Usage {
  id          Int     @id @default(autoincrement())
  apiKeyId    Int
  renderCount Int     @default(0)
  month       Int
  year        Int
  apiKey      ApiKey  @relation(fields: [apiKeyId], references: [id])
  @@unique([apiKeyId, month, year])
}

model UsageDaily {
  id        Int      @id @default(autoincrement())
  apiKeyId  Int
  date      DateTime
  count     Int      @default(0)
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
  @@unique([apiKeyId, date])
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  email     String
  event     String
  status    String
  error     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Render {
  id        Int      @id @default(autoincrement())
  apiKeyId  Int
  status    String   @default("pending")
  progress  Int      @default(0)
  inputUrl  String?
  outputUrl String?
  productId String?
  error     String?
  createdAt DateTime @default(now())
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
}

model TryOnResult {
  id              Int      @id @default(autoincrement())
  userId          Int
  apiKeyId        Int?
  requestId       String?
  garmentId       String?
  productId       String?
  engine          String
  qualityScore    Float?
  candidateCount  Int      @default(1)
  candidateScores Json?
  warnings        Json?
  status          String   @default("generated")
  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
  apiKey          ApiKey?  @relation(fields: [apiKeyId], references: [id])
  feedback        TryOnFeedback[]

  @@index([userId, createdAt])
  @@index([engine, createdAt])
  @@index([status, createdAt])
}

model TryOnFeedback {
  id              Int      @id @default(autoincrement())
  tryOnResultId   Int
  userId          Int
  looksReal       Boolean?
  bodyChanged     Boolean  @default(false)
  garmentChanged  Boolean  @default(false)
  faceChanged     Boolean  @default(false)
  badHands        Boolean  @default(false)
  badNeck         Boolean  @default(false)
  badSleeves      Boolean  @default(false)
  regenerateReason String?
  notes           String?
  createdAt       DateTime @default(now())
  tryOnResult     TryOnResult @relation(fields: [tryOnResultId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([tryOnResultId])
  @@index([userId, createdAt])
}

model Garment {
  id          Int      @id @default(autoincrement())
  userId      Int
  garmentId   String
  displayName String?
  cacheKey    String?
  originalHash String
  originalUrl String?
  sourceImageUrl String?
  thumbnailUrl String?
  productName String?
  category    String?
  garmentType String?
  status      String   @default("missing")
  rejectedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  @@unique([userId, garmentId])
  @@index([userId])
}

model CatalogProduct {
  id          Int      @id @default(autoincrement())
  userId      Int
  productId   String
  productName String?
  category    String?
  garmentType String?
  imageUrl    String?
  source      String?
  status      String   @default("discovered")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([userId])
}

model GarmentMatch {
  id                 Int      @id @default(autoincrement())
  userId             Int
  garmentId          String
  suggestedProductId String?
  confirmedProductId String?
  status             String   @default("unmatched")
  confidence         Float?
  matchReason        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])

  @@unique([userId, garmentId])
  @@index([userId, status])
}

model WebsiteEvent {
  id        Int      @id @default(autoincrement())
  event     String
  path      String?
  visitorId String?
  referrer  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([path, createdAt])
}

model VerificationCode {
  id         Int       @id @default(autoincrement())
  userId     Int?
  email      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id])

  @@index([email, purpose, expiresAt])
  @@index([userId, purpose, expiresAt])
}
